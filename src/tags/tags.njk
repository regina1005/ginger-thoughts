---
layout: layouts/base.njk
pagination:
  data: collections
  size: 1
  alias: tag
  filter:
    - all
    - posts
    - tagList
permalink: /tags/{{ tag | slugify }}/
eleventyComputed:
  title: "{{ tag }}"
---
<section class="tag-page">
  <div class="container">
    <h1 class="tag-page__title">#{{ tag }}</h1>
    <p class="tag-page__count">{{ collections[tag].length }} {% if collections[tag].length == 1 %}Text{% else %}Texte{% endif %}</p>
    <ul class="post-list">
      {%- for post in collections[tag] | reverse %}
      <li class="post-item">
        <div class="post-item__date">{{ post.date | germanDate }}</div>
        <h3 class="post-item__title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        {% if post.data.excerpt %}<p class="post-item__excerpt">{{ post.data.excerpt }}</p>{% endif %}
      </li>
      {%- endfor %}
    </ul>
  </div>
</section>
