---
layout: layouts/base.njk
title: Alle Texte
permalink: /texte/
---
<section class="container">
  <div class="section-header">
    <h2>Alle Texte</h2>
  </div>

  {% if collections.tagList.length > 0 %}
  <div class="tag-cloud" style="margin-bottom:2rem;">
    {% for tag in collections.tagList %}
    <a href="/tags/{{ tag | slugify }}/" class="tag">{{ tag }}</a>
    {% endfor %}
  </div>
  {% endif %}

  <ul class="post-list">
    {%- for post in collections.posts %}
    <li class="post-item">
      <div class="post-item__date">{{ post.date | germanDate }}</div>
      <h3 class="post-item__title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
      {% if post.data.excerpt %}<p class="post-item__excerpt">{{ post.data.excerpt }}</p>{% endif %}
      {% if post.data.tags %}
      <div class="post-item__tags">
        {% for tag in post.data.tags %}
          {% if tag != "posts" %}
          <a href="/tags/{{ tag | slugify }}/" class="tag">{{ tag }}</a>
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}
    </li>
    {%- endfor %}
  </ul>
</section>
