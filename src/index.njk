---
layout: layouts/base.njk
title: Startseite
---
<section class="hero">
  <div class="container">
    <img src="/assets/images/profile.jpg" alt="{{ site.title }}" class="hero__profile">
    <h1>{{ site.title }}</h1>
    <p class="hero__tagline">{{ site.description }}</p>
    <div class="hero__divider"></div>
    <p class="hero__description">Willkommen bei Ginger Thoughts — ein Ort für Gedanken, die im Alltag entstehen. Kleine Texte, ehrliche Momente, ungefilterte Worte.</p>
  </div>
</section>

<section class="container">
  <div class="section-header">
    <h2>Neueste Texte</h2>
  </div>
  <ul class="post-list">
    {%- for post in collections.posts | head(5) %}
    <li class="post-item">
      <div class="post-item__date">{{ post.date | germanDate }}</div>
      <h3 class="post-item__title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
      {% if post.data.excerpt %}<p class="post-item__excerpt">{{ post.data.excerpt }}</p>{% endif %}
      {% if post.data.tags %}
      <div class="post-item__tags">
        {% for tag in post.data.tags %}
          {% if tag != "posts" %}
          <a href="/tags/{{ tag | slugify }}/" class="tag">{{ tag }}</a>
          {% endif %}
        {% endfor %}
      </div>
      {% endif %}
    </li>
    {%- endfor %}
  </ul>
</section>
